# ImagineAI Environment Variables Configuration
# Copy this file to .env and fill in your API tokens.
# Note: For Pollinations.ai (default), no API key is required!

# Hugging Face Inference API token (Free token)
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hugging_face_token_here

# OpenAI API Key (Paid API key for DALL-E)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
